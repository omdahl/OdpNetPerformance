<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!-- oracleDb 19c -->
    <!-- oracleDb 26 ai -->
    <!-- <add name="OracleDb" connectionString="Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=xxx.xxx.xxx.xxx)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=SOMESERVICENAME)));User Id=User;Password=Password;Pooling=true;Min Pool Size=1;Max Pool Size=20;Validate Connection=true;Connection Timeout=60;" /> -->
    <!-- local-home -->
    <add name="OracleDb" connectionString="Data Source=CHANGE_ME;User Id=CHANGE_ME;Password=CHANGE_ME;Pooling=true;Min Pool Size=1;Max Pool Size=20;Validate Connection=true;Connection Timeout=60;" />
  </connectionStrings>
  <appSettings>
    <add key="WarmupIterations" value="3" />
    <add key="ConnectionIterations" value="10" />
    <add key="CrudIterations" value="20" />
    <add key="BenchmarkRowCount" value="2500" />
    <add key="LargeFetchRowCount" value="25000" />
    <add key="FetchSizeIterations" value="4" />
    <add key="FetchSizeReadMode" value="FullRow" />
    <add key="FetchSize256KbBytes" value="262144" />
    <add key="FetchSizeOneMbBytes" value="1048576" />
    <add key="FetchSizeTenMbBytes" value="10485760" />
    <add key="ArrayBindIterations" value="2" />
    <add key="ArrayBindBatchSize" value="1000" />
    <add key="ConcurrentWorkers" value="8" />
    <add key="ConcurrentIterationsPerWorker" value="2" />
    <add key="ConfigureAwaitIterations" value="1" />
    <add key="BenchmarkSampleCount" value="2" />
    <add key="BenchmarkSamplePauseMilliseconds" value="200" />
    <add key="EnableSelfTuning" value="true" />
    <add key="BenchmarkConnectionMode" value="Warm" />
    <add key="SeedBenchmarkData" value="true" />
    <add key="SeedBatchSize" value="1000" />
    <add key="TestTableName" value="ODP_PERF_TEST" />
  </appSettings>
</configuration>

