<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!-- oracleDb 19c -->
    <!-- oracleDb 26 ai -->
    <!-- <add name="OracleDb" connectionString="Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=xxx.xxx.xxx.xxx)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=SOMESERVICENAME)));User Id=User;Password=Password;Pooling=true;Min Pool Size=1;Max Pool Size=20;Validate Connection=true;Connection Timeout=60;" /> -->
    <!-- local-home -->
    <add name="OracleDb" connectionString="Data Source=CHANGE_ME;User Id=CHANGE_ME;Password=CHANGE_ME;Pooling=true;Min Pool Size=1;Max Pool Size=20;Validate Connection=true;Connection Timeout=60;" />
  </connectionStrings>
  <appSettings>
    <add key="WarmupIterations" value="3" />
    <add key="ConnectionIterations" value="10" />
    <add key="CrudIterations" value="20" />
    <add key="BenchmarkRowCount" value="2500" />
    <add key="LargeFetchRowCount" value="25000" />
    <add key="FetchSizeIterations" value="4" />
    <add key="FetchSizeReadMode" value="FullRow" />
    <add key="FetchSize256KbBytes" value="262144" />
    <add key="FetchSizeOneMbBytes" value="1048576" />
    <add key="FetchSizeTenMbBytes" value="10485760" />
    <add key="ArrayBindIterations" value="2" />
    <add key="ArrayBindBatchSize" value="1000" />
    <add key="ConcurrentWorkers" value="8" />
    <add key="ConcurrentIterationsPerWorker" value="2" />
    <add key="ConfigureAwaitIterations" value="1" />
    <add key="BenchmarkSampleCount" value="2" />
    <add key="BenchmarkSamplePauseMilliseconds" value="200" />
    <add key="EnableSelfTuning" value="true" />
    <add key="BenchmarkConnectionMode" value="Warm" />
    <add key="SeedBenchmarkData" value="true" />
    <add key="SeedBatchSize" value="1000" />
    <add key="TestTableName" value="ODP_PERF_TEST" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Buffers" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.4.0" newVersion="4.0.4.0" />
      </dependentAssembly>
    </assemblyBinding>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.2.0" newVersion="4.0.2.0" />
      </dependentAssembly>
    </assemblyBinding>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Numerics.Vectors" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.1.5.0" newVersion="4.1.5.0" />
      </dependentAssembly>
    </assemblyBinding>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.1.0" newVersion="6.0.1.0" />
      </dependentAssembly>
    </assemblyBinding>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Threading.Tasks.Extensions" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.2.1.0" newVersion="4.2.1.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>